<% layout("/layouts/boilerplate") %>

<style>
  #filters{display:flex;flex-wrap:wrap;align-items:center}
  .filter{
    text-align:center;
    margin:2rem 2rem 0 0;
    opacity:.7;
    cursor:pointer;
    transition:.2s;
  }
  .filter:hover,.active{opacity:1}
  .active{border-bottom:2px solid #fe424d}
  .filter i{font-size:1.2rem}
  .filter p{font-size:.8rem}

  .tax-toggle{
    border:1px solid #000;
    border-radius:1rem;
    padding:1rem;
    margin-left:auto;
    height:3.2rem;
    display:flex;
    align-items:center;
  }

  .tax-price,.taxinfo,.hide{display:none}
</style>

<!-- FILTERS -->
<div id="filters">

  <% const filters = [
    ["all","fa-border-all","All"],
    ["Trending","fa-fire","Trending"],
    ["Rooms","fa-bed","Rooms"],
    ["Iconic cities","fa-mountain-city","Iconic cities"],
    ["Mountains","fa-mountain","Mountains"],
    ["Castles","fa-fort-awesome","Castles"],
    ["Amazing Pools","fa-person-swimming","Pools"],
    ["Camping","fa-campground","Camping"],
    ["Farms","fa-cow","Farms"],
    ["Arctic","fa-person-skiing","Arctic"],
    ["Domes","fa-igloo","Domes"],
    ["Boats","fa-ship","Boats"]
  ] %>

  <% filters.forEach(f => { %>
    <div class="filter <%= f[0]=='all'?'active':'' %>" data-category="<%= f[0] %>">
      <i class="fa-solid <%= f[1] %>"></i>
      <p><%= f[2] %></p>
    </div>
  <% }) %>

  <div class="tax-toggle">
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" id="taxSwitch">
      <label class="form-check-label" for="taxSwitch">
        Display Total after Taxes
      </label>
    </div>
  </div>
</div>

<!-- LISTINGS -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

  <% allListings.forEach(listing => { 
    let base = listing.price || 0;
    let gst  = Math.round(base*1.18);
  %>

    <div class="listing-wrapper col"
         data-category="<%= listing.category %>">

      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card">

          <img src="<%= listing.image.url %>"
               class="card-img-top"
               style="height:20rem;object-fit:cover">

          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>

              <span class="base-price">
                &#8377;<%= base.toLocaleString("en-IN") %>/night
              </span>

              <span class="tax-price">
                &#8377;<%= gst.toLocaleString("en-IN") %>/night
              </span>

              <i class="taxinfo"> +18% GST</i>
            </p>
          </div>

        </div>
      </a>
    </div>

  <% }) %>

  <div class="no-results text-center w-100 mt-5"
     id="no-results-msg"
     style="display:none;">

  <i class="fa-solid fa-filter-circle-xmark fs-1 text-secondary"></i>

  <h4 class="mt-3">No listings in this category</h4>

  <a href="/listings/new"
     class="btn btn-dark mt-2"
     id="add-btn">
     Add One
  </a>

</div>

</div>

<script>
  // FILTER
  const filters=document.querySelectorAll(".filter"),
        cards=document.querySelectorAll(".listing-wrapper");

  filters.forEach(f=>{
    f.onclick=()=>{
      filters.forEach(x=>x.classList.remove("active"));
      f.classList.add("active");

      let cat=f.dataset.category;

      let visible = 0;

cards.forEach(c=>{

  let show =
    cat=="all" || c.dataset.category==cat;

  c.style.display = show ? "" : "none";

  if(show) visible++;

});

const noMsg=document.getElementById("no-results-msg");

noMsg.style.display =
  visible ? "none" : "block";

document.getElementById("add-btn").href =
  `/listings/new?category=${encodeURIComponent(cat)}`;
    };
  });

  // GST TOGGLE
  document.getElementById("taxSwitch").onchange=e=>{
    let on=e.target.checked;

    document.querySelectorAll(".base-price")
      .forEach(x=>x.style.display=on?"none":"inline");

    document.querySelectorAll(".tax-price,.taxinfo")
      .forEach(x=>x.style.display=on?"inline":"none");
  };
</script>